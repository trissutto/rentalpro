# ─── BANCO DE DADOS ─────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/rental_system"

# ─── AUTENTICAÇÃO ────────────────────────────────────────────────
# Chave secreta JWT (mude em produção!)
JWT_SECRET="rental-secret-key-change-in-production-use-a-long-random-string"

# ─── WHATSAPP (OPCIONAL) ─────────────────────────────────────────
# Evolution API (recomendado) ou Z-API
WHATSAPP_API_URL="https://api.seudominio.com"
WHATSAPP_API_KEY="sua-chave-api"
WHATSAPP_INSTANCE="rental-instance"

# ─── NEXT.JS ─────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="sua-chave-nextauth"
NODE_ENV="development"

# ─── UPLOAD DE IMAGENS (OPCIONAL) ───────────────────────────────
# Cloudinary para fotos dos imóveis
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
